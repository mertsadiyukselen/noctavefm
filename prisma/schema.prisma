generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Track {
  id        String   @id @default(cuid())
  title     String
  artist    String   @default("")
  audioPath String
  coverPath String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model SiteStats {
  id             Int      @id @default(1)
  liveViewers    Int      @default(220)
  totalListens   Int      @default(1840020)
  listeningNow   Int      @default(48)
  updatedAt      DateTime @updatedAt
}
