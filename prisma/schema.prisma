generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Track {
  id        String   @id @default(cuid())
  title     String
  artist    String   @default("")
  audioPath String
  coverPath String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}
